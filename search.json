---
layout: null
sitemap: false
---
[
{%- assign first = true -%}
{%- for post in site.posts -%}
  {%- unless first %},{% endunless -%}{%- assign first = false %}
  {
    "kind": "note",
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
    "tags": {{ post.tags | jsonify }},
    "description": {{ post.description | default: "" | jsonify }},
    "content": {{ post.content | strip_html | normalize_whitespace | jsonify }}
  }
{%- endfor -%}
{%- for page in site.pages -%}
  {%- if page.title and page.url != "/" and page.url != "/404.html" and page.url != "/tags/" and page.url != "/archive/" and page.name != "search.json" -%}
  {%- unless first %},{% endunless -%}{%- assign first = false %}
  {
    "kind": {% if page.url contains "/art-of-ai/" %}"guide"{% else %}"page"{% endif %},
    "title": {{ page.title | jsonify }},
    "url": {{ page.url | relative_url | jsonify }},
    "date": {{ page.date | date: "%Y-%m-%d" | jsonify }},
    "tags": [],
    "description": {{ page.description | default: "" | jsonify }},
    "content": {{ page.content | strip_html | normalize_whitespace | jsonify }}
  }
  {%- endif -%}
{%- endfor %}
]
